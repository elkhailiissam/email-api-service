{
  "name": "email-api-service",
  "version": "1.0.0",
  "description": "A lightweight, self-hosted email microservice for sending, receiving, and managing emails via REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest",
    "setup": "node setup.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "mailparser": "^3.6.4",
    "node-imap": "^0.9.6",
    "nodemailer": "^6.9.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  },
  "license": "MIT",
  "keywords": [
